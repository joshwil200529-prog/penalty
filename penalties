```html
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Bilateral Asymmetry Penalty Game</title>

<style>

body{
font-family:Arial;
text-align:center;
background:#1b6e2c;
color:white;
}

canvas{
background:#39b54a;
border:3px solid white;
display:block;
margin:auto;
}

button{
padding:10px 20px;
margin:6px;
font-size:16px;
cursor:pointer;
}

#startScreen{
margin-top:40px;
}

#gameUI{
display:none;
}

#powerContainer{
width:260px;
height:26px;
margin:auto;
margin-top:12px;
background:linear-gradient(to right,green,yellow,orange,red);
border:2px solid white;
position:relative;
display:none;
}

#powerIndicator{
width:10px;
height:100%;
background:white;
position:absolute;
left:0;
}

#questionBox{
background:white;
color:black;
padding:15px;
width:420px;
margin:auto;
margin-top:12px;
display:none;
}

#crowdMessage{
font-size:28px;
font-weight:bold;
height:40px;
margin-top:10px;
transition:0.25s;
}

</style>
</head>

<body>

<h1>Bilateral Asymmetry Penalty Shootout</h1>

<div id="startScreen">

<h2>Select Game Mode</h2>

<button onclick="setMode('cpu')">Player vs CPU</button>
<button onclick="setMode('pvp')">Player vs Player</button>

<p>
Choose your shot direction.<br>
Stop the moving power bar.<br>
Answer the asymmetry question.<br>
Correct answers mean the shot goes where intended, but the goalkeeper might still save it!
</p>

</div>


<div id="gameUI">

<div>
<span id="p1Label">Player 1</span>: <span id="playerScore">0</span>
|
<span id="p2Label">CPU</span>: <span id="cpuScore">0</span>
</div>

<canvas id="game" width="650" height="350"></canvas>

<div id="crowdMessage"></div>

<div id="controls">

<p>Choose Direction</p>

<button onclick="chooseDirection('left')">Left</button>
<button onclick="chooseDirection('center')">Centre</button>
<button onclick="chooseDirection('right')">Right</button>

</div>

<div id="powerContainer" onclick="lockPower()">
<div id="powerIndicator"></div>
</div>

<div id="questionBox">

<p id="question"></p>

<button onclick="answer(true)">True</button>
<button onclick="answer(false)">False</button>

</div>

<button id="restart" onclick="restartGame()" style="display:none;">Restart</button>

</div>


<script>

const canvas=document.getElementById("game")
const ctx=canvas.getContext("2d")

let playerScore=0
let cpuScore=0
let round=0
let gameMode="cpu"
let currentPlayer=1

let direction=null
let power=0

let indicatorPos=0
let indicatorDir=1
let powerInterval

let keeperX=325
let keeperTarget=325

let remainingQuestions=[]

const POWER_MAX=248

function setMode(mode){
gameMode=mode
startGame()
}

function crowdMessage(text,color){

let msg=document.getElementById("crowdMessage")

msg.style.color=color
msg.innerText=text
msg.style.transform="scale(1.4)"

setTimeout(()=>{
msg.style.transform="scale(1)"
},200)

}

const questions=[

{q:"Bilateral asymmetry refers to differences between limbs.",a:true},
{q:"Perfect symmetry is required for elite sport.",a:false},
{q:"Large strength asymmetries may increase injury risk.",a:true},
{q:"Asymmetry can occur in strength and balance.",a:true},
{q:"Athletes never develop asymmetries.",a:false},
{q:"Jump tests can assess asymmetry.",a:true},
{q:"Force plates measure asymmetry.",a:true},
{q:"Asymmetry only occurs after injury.",a:false},
{q:"A small amount of asymmetry is common.",a:true},
{q:"Monitoring asymmetry can guide rehab.",a:true},
{q:"Dominant limbs are always stronger.",a:false},
{q:"Strength differences can affect performance.",a:true},
{q:"Training both limbs can reduce asymmetry.",a:true},
{q:"Asymmetry cannot be measured.",a:false},
{q:"ACL injuries can create asymmetry.",a:true}

]

function startGame(){

document.getElementById("startScreen").style.display="none"
document.getElementById("gameUI").style.display="block"

remainingQuestions=[...questions]

if(gameMode==="pvp"){
document.getElementById("p2Label").innerText="Player 2"
}else{
document.getElementById("p2Label").innerText="CPU"
}

drawScene()

}

function drawScene(ballX=325,ballY=270){

ctx.clearRect(0,0,650,350)

ctx.fillStyle="#39b54a"
ctx.fillRect(0,0,650,350)

ctx.fillStyle="white"
ctx.fillRect(225,0,200,100)

ctx.fillRect(320,240,10,30)

ctx.fillStyle="blue"
ctx.fillRect(keeperX-22,80,44,22)

ctx.beginPath()
ctx.arc(ballX,ballY,8,0,Math.PI*2)
ctx.fill()

}

function chooseDirection(dir){

direction=dir
document.getElementById("powerContainer").style.display="block"
startPowerBar()

}

function startPowerBar(){

indicatorPos=0
indicatorDir=1

powerInterval=setInterval(()=>{

indicatorPos+=indicatorDir*10

if(indicatorPos>=POWER_MAX || indicatorPos<=0){
indicatorDir*=-1
}

document.getElementById("powerIndicator").style.left=indicatorPos+"px"

},16)

}

function lockPower(){

clearInterval(powerInterval)
power=indicatorPos/POWER_MAX
document.getElementById("powerContainer").style.display="none"
askQuestion()

}

function askQuestion(){

keeperX=325
keeperTarget=325
drawScene()

if(remainingQuestions.length===0){
remainingQuestions=[...questions]
}

let index=Math.floor(Math.random()*remainingQuestions.length)

currentQuestion=remainingQuestions.splice(index,1)[0]

document.getElementById("question").innerText=currentQuestion.q
document.getElementById("questionBox").style.display="block"

}

function answer(user){

document.getElementById("questionBox").style.display="none"

let correct=user===currentQuestion.a
shoot(correct)

}

function shoot(correct){

let targetX=325

if(direction==="left") targetX=250
if(direction==="right") targetX=400

if(!correct){
targetX+=Math.random()*160-80
}

keeperTarget=[250,325,400][Math.floor(Math.random()*3)]

animateKeeper()

let x=325
let y=270

let dx=(targetX-x)/25
let dy=(90-y)/25

let step=0

let anim=setInterval(()=>{

x+=dx
y+=dy
drawScene(x,y)

step++

if(step>25){
clearInterval(anim)
resolveShot(targetX)
}

},20)

}

function animateKeeper(){

let dive=setInterval(()=>{

keeperX+=(keeperTarget-keeperX)*0.25
drawScene()

if(Math.abs(keeperX-keeperTarget)<2){
clearInterval(dive)
}

},20)

}

function resolveShot(targetX){

let saveChance=0.35

if(targetX===250 || targetX===400){
saveChance=0.25
}

if(Math.abs(keeperX-targetX)<45){
saveChance+=0.4
}

let saved=false

if(Math.random()<saveChance){
saved=true
}

if(power<0.15){
saved=true
}

let goal=!saved

if(goal){

if(currentPlayer===1){
playerScore++
}else{
cpuScore++
}

crowdMessage("⚽ GOAL!", "lime")

}else{

crowdMessage("🧤 GREAT SAVE!", "cyan")

}

nextTurn()

}

function nextTurn(){

if(gameMode==="cpu"){

cpuTurn()

}else{

currentPlayer=currentPlayer===1?2:1

crowdMessage("Player "+currentPlayer+"'s Turn","white")

round++
updateScore()
checkGameEnd()

}

}

function cpuTurn(){

let cpuGoal=Math.random()<0.65

if(cpuGoal){

cpuScore++
crowdMessage("⚽ CPU SCORES","orange")

}else{

crowdMessage("❌ CPU MISSES","red")

}

round++
updateScore()
checkGameEnd()

}

function updateScore(){

document.getElementById("playerScore").innerText=playerScore
document.getElementById("cpuScore").innerText=cpuScore

}

function checkGameEnd(){

if(round<5) return

if(playerScore!==cpuScore){
endGame()
return
}

crowdMessage("🔥 SUDDEN DEATH 🔥","yellow")

}

function endGame(){

let msg="Draw"

if(playerScore>cpuScore) msg="Player 1 Wins!"
if(cpuScore>playerScore) msg=gameMode==="cpu"?"CPU Wins!":"Player 2 Wins!"

crowdMessage(msg,"white")

document.getElementById("restart").style.display="block"

}

function restartGame(){

playerScore=0
cpuScore=0
round=0
currentPlayer=1

remainingQuestions=[...questions]

updateScore()

document.getElementById("crowdMessage").innerText=""
document.getElementById("restart").style.display="none"

drawScene()

}

</script>

</body>
</html>
```
